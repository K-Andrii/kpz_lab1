@model VideoGamesCatalogApp.Models.GameKey

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>GameKey</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="KeyId" />
            <div class="form-group">
                <label asp-for="LicenseKey" class="control-label"></label>
                <input asp-for="LicenseKey" class="form-control" />
                <span asp-validation-for="LicenseKey" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PurchaseDate" class="control-label"></label>
                <input asp-for="PurchaseDate" class="form-control" />
                <span asp-validation-for="PurchaseDate" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsActive" /> @Html.DisplayNameFor(model => model.IsActive)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="GameId" class="control-label"></label>
                <select asp-for="GameId" class="form-control" asp-items="ViewBag.GameId"></select>
                <span asp-validation-for="GameId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StorefrontId" class="control-label"></label>
                <select asp-for="StorefrontId" class="form-control" asp-items="ViewBag.StorefrontId"></select>
                <span asp-validation-for="StorefrontId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CurrentUserId" class="control-label"></label>
                <select asp-for="CurrentUserId" class="form-control" asp-items="ViewBag.CurrentUserId"></select>
                <span asp-validation-for="CurrentUserId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OrderId" class="control-label"></label>
                <select asp-for="OrderId" class="form-control" asp-items="ViewBag.OrderId"></select>
                <span asp-validation-for="OrderId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RevocationReason" class="control-label"></label>
                <input asp-for="RevocationReason" class="form-control" />
                <span asp-validation-for="RevocationReason" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
